@model MachinePortal.Models.MachineEntry

<div class="container mt-5">

    <h2>Edit Machine</h2>

    <form asp-action="Edit" method="post">

        <input type="hidden" asp-for="Id" />

        <input asp-for="TechnicianName" class="form-control mb-2" />
        <input asp-for="BankName" class="form-control mb-2" />
        <input asp-for="Branch" class="form-control mb-2" />
        <input asp-for="MachineType" class="form-control mb-2" />
        <input asp-for="SerialNumber" class="form-control mb-2" />
        <input asp-for="SoftwareVersion" class="form-control mb-2" />

        <button type="submit" class="btn btn-primary">Update</button>
        <a href="/Machine" class="btn btn-secondary">Cancel</a>

    </form>

</div>