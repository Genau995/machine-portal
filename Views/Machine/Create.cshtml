@model MachinePortal.Models.MachineEntry
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
<button type="button"class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div class="container mt-5">

    <div class="row justify-content-center align-items-center">

        <!-- LEFT: FORM -->
        <div class="col-md-5">
            <div class="card shadow p-4" style="border-radius: 15px;">
                <h4 class="text-center mb-4">Machine Entry Form</h4>

                <form asp-action="Create" method="post">

                    <div class="mb-3">
                        <input asp-for="TechnicianName" class="form-control" placeholder="Technician Name" />
                    </div>

                    <div class="mb-3">
                        <input asp-for="BankName" class="form-control" placeholder="Bank Name" />
                    </div>

                    <div class="mb-3">
                        <input asp-for="Branch" class="form-control" placeholder="Branch" />
                    </div>

                    <div class="mb-3">
                        <input asp-for="MachineType" class="form-control" placeholder="Machine Type" />
                    </div>

                    <div class="mb-3">
                        <input asp-for="SerialNumber" class="form-control" placeholder="Serial Number" />
                    </div>

                    <div class="mb-3">
                        <input asp-for="SoftwareVersion" class="form-control" placeholder="Software Version" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Submit Entry
                    </button>

                </form>
            </div>
        </div>

        <!-- RIGHT: LOGO + BRAND -->
        <div class="col-md-5 text-center">
            <img src="~/images/logo.jpeg"
                 style="width:120px; border-radius:12px; box-shadow:0 4px 15px rgba(0,0,0,0.2);" />

            <h3 class="mt-3 fw-bold">GENAU</h3>
            <p class="text-muted">Machine Management Portal</p>
        </div>

    </div>

</div>